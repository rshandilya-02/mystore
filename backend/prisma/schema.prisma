// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  password String 
}

model File {
  id Int @id @default(autoincrement())
  userId String
  storage_key String 
  file_type String
  file_original_name String
  size Int?
  createdAt DateTime @default(now())
}
